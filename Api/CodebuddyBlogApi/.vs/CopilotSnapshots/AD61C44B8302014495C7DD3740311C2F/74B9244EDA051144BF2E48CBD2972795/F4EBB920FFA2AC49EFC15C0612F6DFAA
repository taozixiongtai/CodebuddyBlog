using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using CodebuddyBlogApi.Data;
using CodebuddyBlogApi.Models;
using CodebuddyBlogApi.Dtos;

namespace CodebuddyBlogApi.Controllers
{
    [ApiController]
    [Route("api/[controller]")]
    public class CategoriesController : ControllerBase
    {
        private readonly BlogDbContext _context;

        public CategoriesController(BlogDbContext context)
        {
            _context = context;
        }

        /// <summary>
        /// Get all categories
        /// </summary>
        [HttpGet]
        public ActionResult<ApiResponse<List<CategoryDto>>> GetAll()
        {
            try
            {
                var categories = _context.Categories
                    .OrderByDescending(c => c.CreatedAt)
                    .ToList();

                var dtos = categories.Select(c => new CategoryDto
                {
                    Id = c.Id,
                    Name = c.Name,
                    Description = c.Description,
                    CreatedAt = c.CreatedAt,
                    UpdatedAt = c.UpdatedAt
                }).ToList();

                return Ok(ApiResponse<List<CategoryDto>>.Ok(dtos));
            }
            catch (Exception ex)
            {
                return StatusCode(500, ApiResponse<List<CategoryDto>>.Error($"Error: {ex.Message}"));
            }
        }

        /// <summary>
        /// Get category by id
        /// </summary>
        [HttpGet("{id}")]
        public ActionResult<ApiResponse<CategoryDto>> GetById(int id)
        {
            try
            {
                var category = _context.Categories.FirstOrDefault(c => c.Id == id);
                if (category == null)
                    return NotFound(ApiResponse<CategoryDto>.NotFound("Category not found"));

                var dto = new CategoryDto
                {
                    Id = category.Id,
                    Name = category.Name,
                    Description = category.Description,
                    CreatedAt = category.CreatedAt,
                    UpdatedAt = category.UpdatedAt
                };

                return Ok(ApiResponse<CategoryDto>.Ok(dto));
            }
            catch (Exception ex)
            {
                return StatusCode(500, ApiResponse<CategoryDto>.Error($"Error: {ex.Message}"));
            }
        }

        /// <summary>
        /// Create a new category
        /// </summary>
        [HttpPost]
        public ActionResult<ApiResponse<CategoryDto>> Create([FromBody] CreateCategoryDto dto)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(dto.Name))
                    return BadRequest(ApiResponse<CategoryDto>.BadRequest("Category name is required"));

                var category = new Category
                {
                    Name = dto.Name,
                    Description = dto.Description,
                    CreatedAt = DateTime.Now,
                    UpdatedAt = DateTime.Now
                };

                _context.Categories.Add(category);
                _context.SaveChanges();

                var categoryDto = new CategoryDto
                {
                    Id = category.Id,
                    Name = category.Name,
                    Description = category.Description,
                    CreatedAt = category.CreatedAt,
                    UpdatedAt = category.UpdatedAt
                };

                return CreatedAtAction(nameof(GetById), new { id = category.Id }, 
                    ApiResponse<CategoryDto>.Ok(categoryDto, "Category created successfully"));
            }
            catch (Exception ex)
            {
                return StatusCode(500, ApiResponse<CategoryDto>.Error($"Error: {ex.Message}"));
            }
        }

        /// <summary>
        /// Update a category
        /// </summary>
        [HttpPut("{id}")]
        public ActionResult<ApiResponse<CategoryDto>> Update(int id, [FromBody] UpdateCategoryDto dto)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(dto.Name))
                    return BadRequest(ApiResponse<CategoryDto>.BadRequest("Category name is required"));

                var category = _context.Categories.FirstOrDefault(c => c.Id == id);
                if (category == null)
                    return NotFound(ApiResponse<CategoryDto>.NotFound("Category not found"));

                category.Name = dto.Name;
                category.Description = dto.Description;
                category.UpdatedAt = DateTime.Now;

                _context.Categories.Update(category);
                _context.SaveChanges();

                var categoryDto = new CategoryDto
                {
                    Id = category.Id,
                    Name = category.Name,
                    Description = category.Description,
                    CreatedAt = category.CreatedAt,
                    UpdatedAt = category.UpdatedAt
                };

                return Ok(ApiResponse<CategoryDto>.Ok(categoryDto, "Category updated successfully"));
            }
            catch (Exception ex)
            {
                return StatusCode(500, ApiResponse<CategoryDto>.Error($"Error: {ex.Message}"));
            }
        }

        /// <summary>
        /// Delete a category
        /// </summary>
        [HttpDelete("{id}")]
        public ActionResult<ApiResponse<object>> Delete(int id)
        {
            try
            {
                var category = _context.Categories.FirstOrDefault(c => c.Id == id);
                if (category == null)
                    return NotFound(ApiResponse<object>.NotFound("Category not found"));

                // Check if category has articles
                var articleCount = _context.Articles.Count(a => a.CategoryId == id);
                if (articleCount > 0)
                    return BadRequest(ApiResponse<object>.BadRequest($"Cannot delete category with {articleCount} articles"));

                _context.Categories.Remove(category);
                _context.SaveChanges();

                return Ok(ApiResponse<object>.Ok(null, "Category deleted successfully"));
            }
            catch (Exception ex)
            {
                return StatusCode(500, ApiResponse<object>.Error($"Error: {ex.Message}"));
            }
        }
    }
}
